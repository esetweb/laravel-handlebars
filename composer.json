{
    "name": "proai/laravel-handlebars",
    "description": "A Laravel wrapper for LightnCandy for using the Handlebars (and Mustache) template engine.",
    "keywords": [
        "laravel",
        "lightncandy",
        "handlebars",
        "mustache",
        "template engine"
    ],
    "homepage": "http://github.com/proai/laravel-handlebars",
    "license": "MIT",
    "authors": [
        {
            "name": "Markus J. Wetzel",
            "email": "markuswetzel@gmx.net"
        },
        {
            "name": "Manuel Wieser",
            "email": "office@manuelwieser.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "illuminate/view": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "zordius/lightncandy": "1.2.*"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^9.2|^10.5|^11.0"
    },
    "autoload": {
        "psr-4": {
            "ProAI\\Handlebars\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0-dev"
        }
    }
}
